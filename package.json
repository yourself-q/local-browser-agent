{
  "name": "browser-agent",
  "version": "0.1.0",
  "description": "Local-first browser agent runtime with CDP attachment, accessibility-tree grounding, and event sourcing",
  "type": "module",
  "bin": {
    "browser-agent": "./dist/cli/index.js"
  },
  "scripts": {
    "build": "tsup",
    "dev": "tsx src/cli/index.ts",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0",
    "better-sqlite3": "^12.10.0",
    "chalk": "^5.3.0",
    "commander": "^12.0.0",
    "dotenv": "^16.4.0",
    "express": "^4.19.0",
    "fast-levenshtein": "^3.0.0",
    "inquirer": "^10.1.0",
    "openai": "^4.52.0",
    "pino": "^9.3.0",
    "pino-pretty": "^11.2.0",
    "playwright": "^1.45.0",
    "uuid": "^10.0.0",
    "zod": "^3.23.0",
    "zod-to-json-schema": "^3.23.0"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.0",
    "@types/express": "^4.17.21",
    "@types/fast-levenshtein": "^0.0.4",
    "@types/node": "^22.0.0",
    "@types/uuid": "^10.0.0",
    "tsup": "^8.2.0",
    "tsx": "^4.16.0",
    "typescript": "^5.5.0",
    "vitest": "^2.0.0"
  }
}
