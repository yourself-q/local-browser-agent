# LM Studio OpenAI-compatible endpoint
# NOTE: Use 127.0.0.1, not localhost — LM Studio rejects IPv6 (::1) connections
LM_STUDIO_BASE_URL=http://127.0.0.1:1234/v1
LM_STUDIO_API_KEY=lm-studio

# Target model (must be loaded in LM Studio)
AGENT_MODEL=qwen3.6-35b-a3b-uncensored-hauhaucs-aggressive

# Chrome remote debugging
CHROME_DEBUGGING_PORT=9222
CHROME_DEBUGGING_HOST=localhost

# Session storage directory
SESSIONS_DIR=./sessions

# Logging
LOG_LEVEL=info
LOG_PRETTY=true

# Agent behavior
AGENT_MAX_STEPS=50
# Qwen3-35B is ~10 tok/sec; 4096 max_tokens = up to 400s. Set to 3min minimum.
AGENT_STEP_TIMEOUT_MS=180000
AGENT_MAX_RETRIES=3

# Deterministic mode (0.0 temperature, strict schema, bounded iterations)
DETERMINISTIC_MODE=false

# Human approval mode
HUMAN_APPROVAL_MODE=false

# Screenshots: always | on_failure | never
SCREENSHOT_MODE=on_failure

# MCP server port
MCP_PORT=3000

# OpenAI-compatible API port
API_PORT=8080

# ── LLM generation settings ───────────────────────────────────────────────────
# Max tokens the model may generate per step.
# Qwen3 thinking blocks are 500-2000 tokens; budget 2048 to cover both.
# Set higher (4096) if you see truncated responses.
AGENT_MAX_TOKENS=4096

# Strip <think>...</think> blocks emitted by Qwen3 / DeepSeek-R1 before JSON parsing.
# Set to false only if using a non-thinking model (e.g. llama, mistral).
STRIP_THINKING_BLOCKS=true

# Use response_format: json_object (OpenAI-style JSON mode).
# Most local models don't reliably support this — keep false and use prompt-based JSON.
# Only enable if your model explicitly supports structured output in LM Studio.
JSON_MODE=false

# ── CAPTCHA / human intervention ─────────────────────────────────────────────
# How long to wait for the user to manually solve a CAPTCHA (ms). Default: 5 minutes.
# CAPTCHA_WAIT_TIMEOUT_MS=300000

# ── OpenRouter (alternative to LM Studio / Ollama) ───────────────────────────
# To use OpenRouter, set:
#   LM_STUDIO_BASE_URL=https://openrouter.ai/api/v1
#   LM_STUDIO_API_KEY=<your-openrouter-key>
#   AGENT_MODEL=anthropic/claude-haiku-4-5   (or openai/gpt-4o-mini, google/gemini-flash-1.5, etc.)
#
# Optional headers recommended by OpenRouter:
# OPENROUTER_REFERER=https://github.com/your-username/browser-agent
# OPENROUTER_TITLE=browser-agent

# ── IP block / proxy mitigation ───────────────────────────────────────────────
# This project attaches to your existing Chrome session, so proxy settings must be
# configured at Chrome launch time — not here. Start Chrome with:
#
#   /Applications/Google\ Chrome.app/Contents/MacOS/Google\ Chrome \
#     --remote-debugging-port=9222 \
#     --proxy-server=socks5://127.0.0.1:1080   # or http://proxy-host:port
#
# For residential proxy rotation, use a proxy provider and set their endpoint.
